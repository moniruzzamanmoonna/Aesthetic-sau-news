// firestore.rules
// ─────────────────────────────────────────────────────────────
// Aesthetic SAU News — Role-Based Firestore Security Rules
// Deploy with: firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────

    // Get the caller's Firestore profile
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True if caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // True if caller has at least one of the given roles
    function hasRole(roles) {
      return isAuth() && userDoc().role in roles && userDoc().active == true;
    }

    // Convenience role checks
    function isSuperAdmin() { return hasRole(['super_admin']); }
    function isAdmin()      { return hasRole(['super_admin', 'admin']); }
    function isEditor()     { return hasRole(['super_admin', 'admin', 'editor']); }
    function isJournalist() { return hasRole(['super_admin', 'admin', 'editor', 'journalist']); }
    function isModerator()  { return hasRole(['super_admin', 'admin', 'editor', 'moderator']); }

    // ── /users collection ────────────────────────────────────
    match /users/{uid} {
      // Anyone can create their own profile on first login
      allow create: if isAuth() && request.auth.uid == uid;

      // Users can read their own; admins can read all
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());

      // Users can update their own non-role fields
      allow update: if isAuth() && request.auth.uid == uid
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Only super_admin can change roles
      allow update: if isSuperAdmin();

      // Only super_admin can delete users
      allow delete: if isSuperAdmin();
    }

    // ── /articles collection ─────────────────────────────────
    match /articles/{articleId} {
      // Public reads for published articles (for the homepage)
      allow read: if resource.data.status == 'published'
                  || (isAuth() && isJournalist());

      // Create: journalist and above
      allow create: if isJournalist()
                    && request.resource.data.authorEmail == request.auth.token.email;

      // Update:
      //   - editors+ can edit any article
      //   - journalists can edit only their own (and cannot change status to 'published')
      allow update: if isEditor()
                    || (isJournalist()
                        && resource.data.authorEmail == request.auth.token.email
                        && request.resource.data.status != 'published');

      // Delete: admin+ only
      allow delete: if isAdmin();
    }

    // ── /comments collection ─────────────────────────────────
    match /comments/{commentId} {
      // Public reads
      allow read: if true;

      // Anyone authenticated can create a comment
      allow create: if isAuth();

      // Moderators, editors, admins can update (approve/reject)
      allow update: if isModerator();

      // Admins and moderators can delete
      allow delete: if isModerator();
    }

    // ── /siteConfig collection ───────────────────────────────
    match /siteConfig/{docId} {
      // Public reads (homepage needs lastUpdated)
      allow read: if true;

      // Only admin+ can write config
      allow write: if isAdmin();
    }

    // ── /siteStats collection ────────────────────────────────
    match /siteStats/{docId} {
      allow read: if true;
      // Anyone can increment counters (visit counts etc.)
      allow update: if isAuth() || true; // relax for anonymous visit counts
      allow create: if true;
      allow delete: if isAdmin();
    }

    // ── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
