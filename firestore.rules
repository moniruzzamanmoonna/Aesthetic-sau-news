rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: get caller's role safely ─────────────────────────
    // Returns null if profile doesn't exist yet (first login)
    function getRole() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc.data.get('role', null);
    }

    function isActive() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc.data.get('active', true) == true;
    }

    function isAuth() {
      return request.auth != null;
    }

    // Only check role if user profile exists; otherwise allow basic access
    function profileExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(roles) {
      return isAuth() && profileExists() && getRole() in roles && isActive();
    }

    function isSuperAdmin() { return hasRole(['super_admin']); }
    function isAdmin()      { return hasRole(['super_admin','admin']); }
    function isEditor()     { return hasRole(['super_admin','admin','editor']); }
    function isJournalist() { return hasRole(['super_admin','admin','editor','journalist']); }
    function isModerator()  { return hasRole(['super_admin','admin','editor','moderator']); }

    // ── /users ────────────────────────────────────────────────────
    match /users/{uid} {
      // Anyone authenticated can create their OWN profile (first login)
      allow create: if isAuth() && request.auth.uid == uid;

      // Users can always read their own profile
      // Admins can read all profiles
      allow read: if isAuth() && (
        request.auth.uid == uid || isAdmin()
      );

      // Users can update their own profile BUT cannot change role/active
      allow update: if isAuth() && request.auth.uid == uid
        && !('role'   in request.resource.data.diff(resource.data).affectedKeys())
        && !('active' in request.resource.data.diff(resource.data).affectedKeys());

      // Super Admin can update anything (including role assignment)
      allow update: if isSuperAdmin();

      // Only super_admin can delete
      allow delete: if isSuperAdmin();
    }

    // ── /articles ─────────────────────────────────────────────────
    match /articles/{articleId} {
      // Published articles: public read
      // Staff: can read all
      allow read: if resource.data.get('status','draft') == 'published'
                  || (isAuth() && isJournalist());

      // Create: journalist+, must set own email as author
      allow create: if isJournalist()
        && request.resource.data.get('authorEmail','') == request.auth.token.email;

      // Edit any: editor+
      // Edit own draft only: journalist (cannot self-publish)
      allow update: if isEditor()
        || (
          isJournalist()
          && resource.data.get('authorEmail','') == request.auth.token.email
          && request.resource.data.get('status','draft') != 'published'
        );

      // Delete: admin+
      allow delete: if isAdmin();
    }

    // ── /comments ─────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read:   if true;
      allow create: if isAuth();
      allow update: if isModerator();
      allow delete: if isModerator();
    }

    // ── /siteConfig ───────────────────────────────────────────────
    match /siteConfig/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── /siteStats ────────────────────────────────────────────────
    match /siteStats/{docId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
